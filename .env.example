# ─────────────────────────────────────────────────────────────────
# RetargetCRM — Firebase Environment Variables
# ─────────────────────────────────────────────────────────────────
# 1. Firebase Console → Project Settings → Your Apps → Web App
# 2. Copy these values from the firebaseConfig object
# 3. In Vercel: Settings → Environment Variables → add each one
# ─────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─────────────────────────────────────────────────────────────────
# MUHIM: Firebase Console → Authentication → Settings →
#        Authorized domains → Vercel URL ni qo'shing
#        (masalan: retargetcrm.vercel.app)
# ─────────────────────────────────────────────────────────────────
