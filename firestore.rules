rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════════
// RetargetCRM — Firestore Security Rules v4
// SEC FIX: 
//   - "list" no longer open to all signedIn users
//   - notifications/auditLogs create requires isManagerRole
//   - projects list filtered by membership
// ═══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function currentUserData() {
      return exists(/databases/$(database)/documents/users/$(uid()))
        ? get(/databases/$(database)/documents/users/$(uid())).data
        : null;
    }

    function currentRole() {
      return signedIn() && currentUserData() != null ? currentUserData().roleCode : "";
    }

    function isManagerRole() {
      return currentRole() in ["CEO", "MANAGER", "SUPERVISOR"];
    }

    function isShootManagerRole() {
      let user = currentUserData();
      return isManagerRole() || (
        user != null && (
          user.role == "CEO" ||
          user.title == "CEO" ||
          user.role == "Boshqaruvchi" ||
          user.title == "Boshqaruvchi" ||
          (user.role != null && user.role.matches(".*[Mm]enejer.*")) ||
          (user.title != null && user.title.matches(".*[Mm]enejer.*")) ||
          (user.role != null && user.role.matches(".*[Mm]anager.*")) ||
          (user.title != null && user.title.matches(".*[Mm]anager.*"))
        )
      );
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function canAccessProject(projectData) {
      return signedIn() && projectData != null && (
        isManagerRole() ||
        projectData.managerId == uid() ||
        (projectData.teamIds != null && uid() in projectData.teamIds) ||
        projectData.visibility == "company"
      );
    }

    function canWorkOnProjectData(projectData, projectId) {
      return signedIn() && projectData != null && (
        isManagerRole() ||
        projectData.managerId == uid() ||
        (projectData.teamIds != null && uid() in projectData.teamIds) ||
        (currentUserData() != null && currentUserData().assignedProjectIds != null && projectId in currentUserData().assignedProjectIds)
      );
    }

    function parentProjectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canWorkOnProject(projectId) {
      let p = parentProjectData(projectId);
      return signedIn() && (
        isManagerRole() ||
        p.managerId == uid() ||
        (p.teamIds != null && uid() in p.teamIds) ||
        (currentUserData() != null && currentUserData().assignedProjectIds != null && projectId in currentUserData().assignedProjectIds)
      );
    }

    function canReadSubcollection(projectId) {
      let p = parentProjectData(projectId);
      return signedIn() && (
        isManagerRole() ||
        p.managerId == uid() ||
        (p.teamIds != null && uid() in p.teamIds) ||
        (currentUserData() != null && currentUserData().assignedProjectIds != null && projectId in currentUserData().assignedProjectIds) ||
        p.visibility == "company"
      );
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:           if signedIn();
      allow create:         if signedIn() && (isSelf(userId) || isManagerRole());
      allow update:         if signedIn() && (isSelf(userId) || isManagerRole());
      allow delete:         if isManagerRole();
    }

    match /userPrivate/{userId} {
      allow read:           if isSelf(userId) || isManagerRole();
      allow create, update: if isSelf(userId) || isManagerRole();
      allow delete:         if isManagerRole();
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    // App uses client-side filtering after a collection subscription.
    match /projects/{projectId} {
      allow list:           if signedIn();
      allow get:            if canAccessProject(resource.data);
      allow create:         if isManagerRole();
      allow update:         if isManagerRole()
                              || resource.data.managerId == uid()
                              || (
                                canWorkOnProjectData(resource.data, projectId) &&
                                request.resource.data.diff(resource.data).affectedKeys()
                                  .hasOnly(["metrics", "memberStats", "updatedAt", "updatedBy"])
                              );
      allow delete:         if isManagerRole();

      match /tasks/{taskId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
      match /content/{contentId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
      match /mediaPlans/{mediaId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
      match /plans/{planId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
      match /calls/{callId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
      match /designTasks/{taskId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
      match /targetTasks/{taskId} {
        allow read:               if canReadSubcollection(projectId);
        allow create, update, delete: if canWorkOnProject(projectId);
      }
    }

    // ── Shoots ────────────────────────────────────────────────────────────────
    match /shoots/{shootId} {
      allow list:           if signedIn();
      allow get:            if signedIn();
      allow create:         if canWorkOnProject(request.resource.data.projectId);
      allow update, delete: if canWorkOnProject(resource.data.projectId) || resource.data.operatorId == uid() || isShootManagerRole();
    }

    // ── Meetings ──────────────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      allow read:                  if signedIn();
      allow create, update, delete: if isManagerRole();
    }

    // ── Chat ──────────────────────────────────────────────────────────────────
    match /chatMessages/{messageId} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow update: if signedIn() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]) ||
        resource.data.userId == uid() ||
        isManagerRole()
      );
      allow delete: if signedIn() && (
        resource.data.userId == uid() || isManagerRole()
      );
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // SEC-03 FIX: create restricted to managers only
    match /notifications/{notificationId} {
      allow read:   if signedIn();
      allow create: if isManagerRole();
      allow update: if signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]);
      allow delete: if isManagerRole();
    }

    match /financialSnapshots/{snapshotId} {
      allow read, create, update, delete: if signedIn() && currentRole() == "CEO";
    }

    // ── Audit Logs ────────────────────────────────────────────────────────────
    // SEC-03 FIX: create restricted to managers only
    match /auditLogs/{logId} {
      allow read:           if signedIn();
      allow create:         if isManagerRole();
      allow update, delete: if isManagerRole();
    }

    // ── Legacy / Migration ────────────────────────────────────────────────────
    match /crm/{crmId} {
      allow read, write: if isManagerRole();
    }

    match /crmMeta/{metaId} {
      allow read, write: if isManagerRole();
    }
  }
}
