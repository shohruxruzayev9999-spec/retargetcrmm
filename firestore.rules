// firestore.rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() {
      return getProfile().role;
    }
    function isCEO()        { return isAuth() && role() == 'ceo'; }
    function isManager()    { return isAuth() && role() == 'manager'; }
    function isSupervisor() { return isAuth() && role() == 'supervisor'; }
    function isInvestor()   { return isAuth() && role() == 'investor'; }
    function isEmployee()   { return isAuth() && role() == 'employee'; }
    function canManage()    { return isCEO() || isManager() || isSupervisor(); }

    // ── users ──────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isCEO() || request.auth.uid == uid;
    }

    // ── userPrivate (salary) ───────────────────────────
    match /userPrivate/{uid} {
      allow read:  if isCEO() || request.auth.uid == uid;
      allow write: if isCEO();
    }

    // ── projects ───────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isAuth() && (
        canManage() ||
        isInvestor() ||
        (isEmployee() && request.auth.uid in resource.data.teamIds)
      );
      allow create, update: if canManage();
      allow delete: if isCEO();

      // Sub-collections
      match /{sub}/{docId} {
        allow read: if isAuth() && (
          canManage() ||
          isInvestor() ||
          (isEmployee() && request.auth.uid in
            get(/databases/$(database)/documents/projects/$(projectId)).data.teamIds)
        );
        allow write: if canManage();
      }
    }

    // ── shoots ─────────────────────────────────────────
    match /shoots/{id} {
      allow read: if isAuth();
      allow write: if canManage();
    }

    // ── meetings ───────────────────────────────────────
    match /meetings/{id} {
      allow read: if isAuth();
      allow write: if canManage();
    }

    // ── notifications ──────────────────────────────────
    match /notifications/{id} {
      allow read:   if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if isCEO();
    }
  }
}
