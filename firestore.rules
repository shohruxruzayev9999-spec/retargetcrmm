rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(currentUserPath());
    }

    function currentUserData() {
      return hasUserProfile() ? get(currentUserPath()).data : null;
    }

    function currentRole() {
      return currentUserData() != null ? currentUserData().roleCode : "";
    }

    function isManagerRole() {
      return currentRole() in ["CEO", "MANAGER", "SUPERVISOR"];
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function projectPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function hasProject(projectId) {
      return exists(projectPath(projectId));
    }

    function projectData(projectId) {
      return hasProject(projectId) ? get(projectPath(projectId)).data : null;
    }

    function isProjectMember(projectId) {
      return signedIn() &&
        hasProject(projectId) &&
        (
          projectData(projectId).managerId == request.auth.uid ||
          (projectData(projectId).teamIds != null && request.auth.uid in projectData(projectId).teamIds)
        );
    }

    function canReadProject(projectId) {
      return signedIn() &&
        hasProject(projectId) &&
        (
          isManagerRole() ||
          isProjectMember(projectId) ||
          projectData(projectId).visibility == "company"
        );
    }

    function canWorkProject(projectId) {
      return signedIn() && (isManagerRole() || isProjectMember(projectId));
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && (isSelf(userId) || isManagerRole());
      allow update: if signedIn() && (isSelf(userId) || isManagerRole());
      allow delete: if isManagerRole();
    }

    match /userPrivate/{userId} {
      allow read: if isSelf(userId) || isManagerRole();
      allow create, update: if isSelf(userId) || isManagerRole();
      allow delete: if isManagerRole();
    }

    match /projects/{projectId} {
      allow read: if canReadProject(projectId);
      allow create, update, delete: if isManagerRole();

      match /tasks/{taskId} {
        allow read: if canReadProject(projectId);
        allow create, update, delete: if canWorkProject(projectId);
      }

      match /content/{contentId} {
        allow read: if canReadProject(projectId);
        allow create, update, delete: if canWorkProject(projectId);
      }

      match /mediaPlans/{mediaId} {
        allow read: if canReadProject(projectId);
        allow create, update, delete: if canWorkProject(projectId);
      }

      match /plans/{planId} {
        allow read: if canReadProject(projectId);
        allow create, update, delete: if canWorkProject(projectId);
      }

      match /calls/{callId} {
        allow read: if canReadProject(projectId);
        allow create, update, delete: if canWorkProject(projectId);
      }

      match /shoots/{shootId} {
        allow read: if canReadProject(projectId);
        allow create, update, delete: if canWorkProject(projectId);
      }
    }

    match /shoots/{shootId} {
      allow read: if signedIn() && canReadProject(resource.data.projectId);
      allow create: if signedIn() && canWorkProject(request.resource.data.projectId);
      allow update, delete: if signedIn() && canWorkProject(resource.data.projectId);
    }

    match /meetings/{meetingId} {
      allow read: if signedIn();
      allow create, update, delete: if isManagerRole();
    }

    match /chatMessages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() &&
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]) ||
          resource.data.userId == request.auth.uid ||
          isManagerRole()
        );
      allow delete: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isManagerRole()
        );
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isManagerRole();
    }

    match /auditLogs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isManagerRole();
    }

    match /crm/{crmId} {
      allow read, write: if signedIn();
    }

    match /crmMeta/{metaId} {
      allow read, write: if signedIn();
    }
  }
}
