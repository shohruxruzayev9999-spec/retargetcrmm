rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// RetargetCRM — Firestore Security Rules v3
// FIX: resource.data is NULL on list/collection queries.
//      Split "read" into "get" (single doc) and "list" (query).
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function currentRole() {
      return signedIn() ? currentUserData().roleCode : "";
    }

    function isManagerRole() {
      return currentRole() in ["CEO", "MANAGER", "SUPERVISOR"];
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    // For single-doc project reads: use resource.data (no extra get() needed)
    function canGetProject(projectData) {
      return signedIn() && (
        isManagerRole() ||
        projectData.managerId == uid() ||
        (projectData.teamIds != null && uid() in projectData.teamIds) ||
        projectData.visibility == "company"
      );
    }

    // For subcollection writes: need one parent get()
    function parentProjectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canWorkOnProject(projectId) {
      let p = parentProjectData(projectId);
      return signedIn() && (
        isManagerRole() ||
        p.managerId == uid() ||
        (p.teamIds != null && uid() in p.teamIds)
      );
    }

    function canReadSubcollection(projectId) {
      let p = parentProjectData(projectId);
      return signedIn() && (
        isManagerRole() ||
        p.managerId == uid() ||
        (p.teamIds != null && uid() in p.teamIds) ||
        p.visibility == "company"
      );
    }

    // ── Users ─────────────────────────────────────────────────────

    match /users/{userId} {
      allow read:   if signedIn();
      allow create: if signedIn() && (isSelf(userId) || isManagerRole());
      allow update: if signedIn() && (isSelf(userId) || isManagerRole());
      allow delete: if isManagerRole();
    }

    match /userPrivate/{userId} {
      allow read:           if isSelf(userId) || isManagerRole();
      allow create, update: if isSelf(userId) || isManagerRole();
      allow delete:         if isManagerRole();
    }

    // ── Projects ──────────────────────────────────────────────────
    // KEY FIX: "list" (collection query) → allow all signed-in users.
    //   Frontend visibleProjects() filters by role.
    // "get" (single doc) → strict check via resource.data (no extra get).

    match /projects/{projectId} {
      allow list:           if signedIn();                          // onSnapshot collection
      allow get:            if canGetProject(resource.data);        // single doc fetch
      allow create:         if isManagerRole();
      allow update:         if isManagerRole();
      allow delete:         if isManagerRole();

      match /tasks/{taskId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWorkOnProject(projectId);
      }

      match /content/{contentId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWorkOnProject(projectId);
      }

      match /mediaPlans/{mediaId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWorkOnProject(projectId);
      }

      match /plans/{planId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWorkOnProject(projectId);
      }

      match /calls/{callId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWorkOnProject(projectId);
      }
    }

    // ── Shoots ────────────────────────────────────────────────────

    match /shoots/{shootId} {
      allow list:   if signedIn();
      allow get:    if signedIn();
      allow create: if canWorkOnProject(request.resource.data.projectId);
      allow update,
            delete: if canWorkOnProject(resource.data.projectId);
    }

    // ── Meetings ──────────────────────────────────────────────────

    match /meetings/{meetingId} {
      allow read:           if signedIn();
      allow create,
            update,
            delete:         if isManagerRole();
    }

    // ── Chat ──────────────────────────────────────────────────────

    match /chatMessages/{messageId} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow update: if signedIn() && (
        // Only readBy field changed → any signed-in user (mark as read)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]) ||
        resource.data.userId == uid() ||
        isManagerRole()
      );
      allow delete: if signedIn() && (
        resource.data.userId == uid() || isManagerRole()
      );
    }

    // ── Notifications ─────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isManagerRole();
    }

    // ── Audit Logs ────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read:           if signedIn();
      allow create:         if signedIn();
      allow update, delete: if isManagerRole();
    }

    // ── Legacy root ───────────────────────────────────────────────

    match /crm/{crmId} {
      allow read, write: if signedIn();
    }

    match /crmMeta/{metaId} {
      allow read, write: if signedIn();
    }
  }
}
