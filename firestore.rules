rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    // Reads user doc once and caches in the call; avoids repeated get() calls.
    function currentUserData() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function currentRole() {
      let d = currentUserData();
      return d != null ? d.roleCode : "";
    }

    function isManagerRole() {
      return currentRole() in ["CEO", "MANAGER", "SUPERVISOR"];
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // ── Project helpers (use resource.data to avoid extra get()) ─────────────

    function isProjectMemberFromData(projectData) {
      return signedIn() && (
        projectData.managerId == request.auth.uid ||
        (projectData.teamIds != null && request.auth.uid in projectData.teamIds)
      );
    }

    function canReadProjectFromData(projectData) {
      return signedIn() && (
        isManagerRole() ||
        isProjectMemberFromData(projectData) ||
        projectData.visibility == "company"
      );
    }

    // For subcollections we still need a parent get — minimised to one call.
    function parentProject(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canReadSubcollection(projectId) {
      let p = parentProject(projectId);
      return canReadProjectFromData(p);
    }

    function canWriteSubcollection(projectId) {
      let p = parentProject(projectId);
      return isManagerRole() || isProjectMemberFromData(p);
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && (isSelf(userId) || isManagerRole());
      allow update: if signedIn() && (isSelf(userId) || isManagerRole());
      allow delete: if isManagerRole();
    }

    match /userPrivate/{userId} {
      allow read:   if isSelf(userId) || isManagerRole();
      allow create,
            update: if isSelf(userId) || isManagerRole();
      allow delete: if isManagerRole();
    }

    // ── Projects ──────────────────────────────────────────────────────────────

    match /projects/{projectId} {
      allow read:   if canReadProjectFromData(resource.data);
      allow create: if isManagerRole();
      allow update: if isManagerRole();
      allow delete: if isManagerRole();

      match /tasks/{taskId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWriteSubcollection(projectId);
      }

      match /content/{contentId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWriteSubcollection(projectId);
      }

      match /mediaPlans/{mediaId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWriteSubcollection(projectId);
      }

      match /plans/{planId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWriteSubcollection(projectId);
      }

      match /calls/{callId} {
        allow read:             if canReadSubcollection(projectId);
        allow create,
              update,
              delete:           if canWriteSubcollection(projectId);
      }
    }

    // ── Shoots ────────────────────────────────────────────────────────────────

    match /shoots/{shootId} {
      allow read:   if signedIn() && canReadProjectFromData(
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data
                    );
      allow create: if signedIn() && canWriteSubcollection(request.resource.data.projectId);
      allow update,
            delete: if signedIn() && canWriteSubcollection(resource.data.projectId);
    }

    // ── Meetings ──────────────────────────────────────────────────────────────

    match /meetings/{meetingId} {
      allow read:             if signedIn();
      allow create,
            update,
            delete:           if isManagerRole();
    }

    // ── Chat ──────────────────────────────────────────────────────────────────

    match /chatMessages/{messageId} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (
        // Anyone can mark message as read (only readBy field changes)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]) ||
        // Author can edit their own message
        resource.data.userId == request.auth.uid ||
        // Managers can edit/moderate
        isManagerRole()
      );
      allow delete: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagerRole()
      );
    }

    // ── Notifications ─────────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read:   if signedIn();
      allow create: if signedIn();
      // Anyone can update readBy on their own notification; managers can do anything
      allow update: if signedIn();
      allow delete: if isManagerRole();
    }

    // ── Audit Logs ────────────────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update,
            delete: if isManagerRole();
    }

    // ── Legacy root (kept for migration) ─────────────────────────────────────

    match /crm/{crmId} {
      allow read, write: if signedIn();
    }

    match /crmMeta/{metaId} {
      allow read, write: if signedIn();
    }
  }
}
